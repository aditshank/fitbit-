# Google Cloud OAuth 2.0 credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# Gemini API key (from Google AI Studio https://aistudio.google.com/)
# Free tier - no credit card required
GEMINI_API_KEY=your-gemini-api-key-here

# FatSecret Platform API (primary food recognition)
FATSECRET_CONSUMER_KEY=your-fatsecret-consumer-key
FATSECRET_CONSUMER_SECRET=your-fatsecret-consumer-secret

# FastAPI secret for session encoding
SESSION_SECRET_KEY=generate-a-random-secret-key-here

# App settings
APP_NAME=Calorie Tracker
